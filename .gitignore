# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# Claude Code — track shared config (skills, CLAUDE.md), ignore local-only
.claude/settings.local.json
.claude/.session*

# JetBrains IDEs
.idea/

# VS Code
.vscode/

# Vim swap files
*.swp

# typescript
*.tsbuildinfo

# Firebase config files (if added later)
GoogleService-Info.plist
google-services.json

# generated native folders
/ios
/android

# Documents & PDFs
*.pdf
